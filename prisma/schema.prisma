generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  email         String   @unique
  passwordHash  String?
  name          String?
  role          String   @default("USER")
  googleId      String?
  authProvider  String   @default("EMAIL")
  emailVerified Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model EmailOtp {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
}

model HeroSetting {
  id                 String   @id @map("_id")
  mediaType          String   @default("video")
  mediaUrl           String   @default("")
  cloudinaryPublicId String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model StoreCategory {
  id                 String   @id @default(auto()) @map("_id") @db.ObjectId
  name               String   @unique
  slug               String   @unique
  imageUrl           String   @default("")
  imagePublicId      String?
  sortOrder          Int      @default(0)
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Product {
  id                 String   @id @default(auto()) @map("_id") @db.ObjectId
  name               String
  slug               String   @unique
  description        String?
  detailsHtml        String?
  category           String
  originalPrice      Float
  priceAfterDiscount Float?
  badge              String?
  imageUrl           String
  hoverImageUrl      String?
  imagePublicId      String?
  hoverImagePublicId String?
  galleryImageUrls      String[] @default([])
  galleryImagePublicIds String[] @default([])
  stock              Int      @default(0)
  status             String   @default("DRAFT")
  isPopular          Boolean  @default(false)
  deliveryType       String   @default("FREE")
  deliveryCharge     Float?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model InboundSubmission {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  type      String
  firstName String?
  lastName  String?
  email     String
  phone     String?
  message   String?
  status    String   @default("NEW")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Order {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  orderNumber     String   @unique
  userId          String   @db.ObjectId
  status          String   @default("pending")
  paymentMethod   String   @default("Cash on Delivery")
  subtotal        Float
  deliveryTotal   Float
  total           Float
  customerName    String
  customerEmail   String
  customerPhone   String
  customerAddress String
  customerCity    String
  customerNotes   String?
  items           Json
  stockAdjusted   Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
}
